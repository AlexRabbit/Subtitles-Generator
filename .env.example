# Subtitles Generator — copy to .env and adjust

# Server
HOST=127.0.0.1
PORT=8765
BIND_HOST=0.0.0.0
LAN_ONLY=true
DEBUG=false

# Whisper
WHISPER_MODEL=base
WHISPER_DEVICE=cuda
USE_CUDA=true
MODELS_DIR=models

# FFmpeg (leave empty to auto-detect; or set e.g. ffmpeg\bin\ffmpeg.exe)
FFMPEG_PATH=

# Logging
LOG_LEVEL=DEBUG
LOG_DIR=logs

# Queue
MAX_QUEUE_SIZE=1000

# Translation
TRANSLATION_BATCH_SIZE=20
TRANSLATION_RETRY_COUNT=3
